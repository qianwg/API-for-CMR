import requests

# API 地址
url = 'http://127.0.0.1:5000/predict'

# 输入数据
data = {
    "Basal_metabolic_rate": 5088.0,
    "Standing_height": 155.0,
    "Sex": "Female",
    "Testosterone": 0.737,
    "Weight": 65.6,
    "Waist_circumference": 77.0,
    "FVC": 2.28,
    "FEV1": 1.63,
    "Creatinine": 55.7,
    "Urate": 351.7
}

# 发送 POST 请求
response = requests.post(url, json=data)
print(response.json())